---
import { siteConfig } from '../../lib/content/site';
import { isValidWhatsappNumber } from '../../lib/storefront';

const hasWhatsapp = isValidWhatsappNumber(siteConfig.whatsappNumber);
---

<div class="bag-backdrop" id="bag-backdrop" hidden></div>

<aside class="bag-drawer" id="bag-drawer" aria-labelledby="bag-title" aria-hidden="true">
	<div class="bag-header">
		<div>
			<span class="section-label">Shopping bag</span>
			<h2 id="bag-title">Your bag</h2>
		</div>

		<button class="icon-button" type="button" data-close-bag aria-label="Close bag">
			&times;
		</button>
	</div>

	<div class="bag-body">
		<div id="bag-items" class="bag-items">
			<article class="bag-empty">
				<strong>Your bag is empty.</strong>
				<p class="bag-empty-copy">
					Browse the collection and add pieces you love.
				</p>
			</article>
		</div>
	</div>

	<div class="bag-footer">
		<div class="bag-total">
			<span>Estimated total</span>
			<strong id="bag-total">Rp0</strong>
		</div>

		<p class="bag-note">You'll review your order and choose a payment method.</p>

		<button class="button button-primary button-block" id="checkout-button" type="button">
			Checkout
		</button>

		{hasWhatsapp && (
			<p class="bag-whatsapp-link">
				Have questions? <a href={`https://wa.me/${siteConfig.whatsappNumber.replace(/\D/g, '')}`} target="_blank" rel="noopener">Chat on WhatsApp</a>
			</p>
		)}
	</div>
</aside>
